{
    "name": "CCM - Agency Onboarding → Dashboard",
    "flow": [
        {
            "id": 1,
            "module": "app#call-center-mastery-qeqot5:watchEventsManualPlacement",
            "version": 1,
            "parameters": {
                "__IMTHOOK__": 0
            },
            "mapper": {},
            "metadata": {
                "designer": { "x": 0, "y": 0 },
                "restore": {
                    "parameters": {
                        "__IMTHOOK__": {
                            "data": { "editable": "false" },
                            "label": "CRM Status Webhook — fires when agency status changes"
                        }
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTHOOK__",
                        "type": "hook:app#call-center-mastery-qeqot53",
                        "label": "Webhook",
                        "required": true
                    }
                ]
            }
        },
        {
            "id": 2,
            "module": "http:ActionSendData",
            "version": 3,
            "parameters": {
                "handleErrors": false,
                "useNewZLibDeCompression": true
            },
            "mapper": {
                "url": "https://wm-os-production.up.railway.app/api/admin/onboard",
                "serializeUrl": false,
                "method": "POST",
                "headers": [
                    {
                        "name": "Authorization",
                        "value": "Bearer REPLACE_WITH_YOUR_ADMIN_WEBHOOK_SECRET"
                    },
                    {
                        "name": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "qs": [],
                "bodyType": "raw",
                "parseResponse": false,
                "authUser": "",
                "authPass": "",
                "timeout": "",
                "shareCookies": false,
                "ca": "",
                "useMtls": false,
                "contentType": "application/json",
                "data": "{\"agency_name\": \"{{1.agency_name}}\", \"email\": \"{{1.email}}\", \"status\": \"{{1.status}}\"}"
            },
            "metadata": {
                "designer": { "x": 300, "y": 0, "name": "Create/Update Agency Account" }
            }
        }
    ],
    "metadata": {
        "instant": true,
        "version": 1,
        "scenario": {
            "roundtrips": 1,
            "maxErrors": 3,
            "autoCommit": true,
            "autoCommitTriggerLast": true,
            "sequential": false,
            "confidential": false,
            "dataloss": false,
            "dlq": false,
            "freshVariables": false
        },
        "designer": { "orphans": [] },
        "zone": "eu1.make.com"
    }
}
