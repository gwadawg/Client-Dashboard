{
    "name": "CCM - All Dials → Supabase",
    "flow": [
        {
            "id": 1,
            "module": "app#call-center-mastery-qeqot5:watchEventsManualPlacement",
            "version": 1,
            "parameters": {
                "__IMTHOOK__": 0
            },
            "mapper": {},
            "metadata": {
                "designer": { "x": 0, "y": 0 },
                "restore": {
                    "parameters": {
                        "__IMTHOOK__": {
                            "data": { "editable": "false" },
                            "label": "Dial Webhook — create new and point GHL here"
                        }
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTHOOK__",
                        "type": "hook:app#call-center-mastery-qeqot53",
                        "label": "Webhook",
                        "required": true
                    }
                ]
            }
        },
        {
            "id": 2,
            "module": "http:ActionSendData",
            "version": 3,
            "parameters": {
                "handleErrors": false,
                "useNewZLibDeCompression": true
            },
            "filter": {
                "name": "Has call start time",
                "conditions": [
                    [
                        {
                            "a": "{{1.customData.`Phone Call Start Time`}}",
                            "o": "exist"
                        }
                    ]
                ]
            },
            "mapper": {
                "url": "https://wm-os-production.up.railway.app/api/webhooks",
                "serializeUrl": false,
                "method": "POST",
                "headers": [
                    {
                        "name": "Authorization",
                        "value": "Bearer Gabe0322!"
                    },
                    {
                        "name": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "qs": [],
                "bodyType": "raw",
                "parseResponse": false,
                "authUser": "",
                "authPass": "",
                "timeout": "",
                "shareCookies": false,
                "ca": "",
                "useMtls": false,
                "contentType": "application/json",
                "data": "{\"event_type\": \"dial\", \"client_name\": \"{{trim(1.location.name)}}\", \"ghl_contact_id\": \"{{1.contact_id}}\", \"occurred_at\": \"{{formatDate(1.customData.`Phone Call Start Time`; \\\"YYYY-MM-DDTHH:mm:ss\\\")}}\", \"duration_seconds\": {{toNumber(ifempty(1.customData.`Call Duration`; 0))}}, \"is_pickup\": {{if(toNumber(ifempty(1.customData.`Call Duration`; 0)) >= 40; true; false)}}, \"is_conversation\": {{if(toNumber(ifempty(1.customData.`Call Duration`; 0)) >= 120; true; false)}}, \"recording_url\": \"{{ifempty(1.customData.`Attachment `; ifempty(1.customData.`Message Attachments`; 1.customData.`Recording URL`))}}\"}"
            },
            "metadata": {
                "designer": { "x": 300, "y": 0, "name": "Send to Supabase" }
            }
        }
    ],
    "metadata": {
        "instant": true,
        "version": 1,
        "scenario": {
            "roundtrips": 1,
            "maxErrors": 3,
            "autoCommit": true,
            "autoCommitTriggerLast": true,
            "sequential": false,
            "confidential": false,
            "dataloss": false,
            "dlq": false,
            "freshVariables": false
        },
        "designer": { "orphans": [] },
        "zone": "eu1.make.com"
    }
}
